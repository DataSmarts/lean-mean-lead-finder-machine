# Database (Neon)
DATABASE_URL=postgres://user:password@host/db?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:password@host/db?sslmode=require

# Neon CLI — used for the local integration test procedure (see CLAUDE.md Commands section)
NEON_PROJECT_ID=
NEON_ROLE_NAME=neondb_owner

# Google
GOOGLE_MAPS_API_KEY=

# Hunter.io
HUNTER_API_KEY=
HUNTER_LIMIT=5

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview:online

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Auth
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Min 32 chars; HMAC key for the session cookie. Generate: openssl rand -base64 32
SESSION_SECRET=

# Trigger.dev
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# App
APP_BASE_URL=http://localhost:3000
